#!/usr/bin/env bash
# List or kill long-running `claude` processes.
#
# Usage:
#   claude-kill-stale              # list processes older than 1h
#   claude-kill-stale -t 7200      # list processes older than 2h
#   claude-kill-stale -k           # kill processes older than 1h (SIGTERM)
#   claude-kill-stale -k -9        # kill with SIGKILL
set -euo pipefail

threshold=3600
do_kill=0
signal=TERM

while [[ $# -gt 0 ]]; do
  case "$1" in
    -t|--threshold) threshold="$2"; shift 2 ;;
    -k|--kill) do_kill=1; shift ;;
    -9) signal=KILL; shift ;;
    -h|--help) sed -n '2,8p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *) echo "unknown arg: $1" >&2; exit 2 ;;
  esac
done

mapfile -t rows < <(ps -eo pid,etimes,comm | awk -v t="$threshold" '$3 == "claude" && $2 > t {print $1, $2}')

if [[ ${#rows[@]} -eq 0 ]]; then
  echo "No claude processes older than ${threshold}s."
  exit 0
fi

fmt_elapsed() {
  local s=$1
  printf '%dh%02dm' $((s / 3600)) $(((s % 3600) / 60))
}

printf '%-8s %-10s\n' PID ELAPSED
for r in "${rows[@]}"; do
  pid="${r%% *}"
  secs="${r##* }"
  printf '%-8s %-10s\n' "$pid" "$(fmt_elapsed "$secs")"
done

if [[ $do_kill -eq 1 ]]; then
  echo
  for r in "${rows[@]}"; do
    pid="${r%% *}"
    echo "kill -$signal $pid"
    kill -"$signal" "$pid" || true
  done
fi
