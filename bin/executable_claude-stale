#!/usr/bin/env bash
# List long-running `claude` processes.
#
# Usage:
#   claude-stale              # pretty list, processes older than 1h
#   claude-stale -t 7200      # threshold 2h
#   claude-stale -p           # PIDs only — pipe to xargs:
#                                  #   claude-stale -p | xargs -r kill
set -euo pipefail

threshold=3600
pids_only=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    -t|--threshold) threshold="$2"; shift 2 ;;
    -p|--pids) pids_only=1; shift ;;
    -h|--help) sed -n '2,7p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *) echo "unknown arg: $1" >&2; exit 2 ;;
  esac
done

mapfile -t rows < <(ps -eo pid,etimes,comm | awk -v t="$threshold" '$3 == "claude" && $2 > t {print $1, $2}')

if [[ $pids_only -eq 1 ]]; then
  for r in "${rows[@]}"; do
    printf '%s\n' "${r%% *}"
  done
  exit 0
fi

if [[ ${#rows[@]} -eq 0 ]]; then
  echo "No claude processes older than ${threshold}s."
  exit 0
fi

fmt_elapsed() {
  local s=$1
  printf '%dh%02dm' $((s / 3600)) $(((s % 3600) / 60))
}

printf '%-8s %-10s\n' PID ELAPSED
for r in "${rows[@]}"; do
  pid="${r%% *}"
  secs="${r##* }"
  printf '%-8s %-10s\n' "$pid" "$(fmt_elapsed "$secs")"
done
