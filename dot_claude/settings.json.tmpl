    "ask": [],
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable",
    "enableAllProjectMcpServers": false
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {},
  "effortLevel": "medium",
  "skipAutoPermissionPrompt": true
