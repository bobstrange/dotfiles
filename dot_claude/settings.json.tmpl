      "Bash(git symbolic-ref *)",
      "Bash(git rev-parse:*)",
      "Bash(git merge-base:*)",
      "Bash(ghq:*)",
      "// === GitHub CLI ===",
      "Bash(gh:*)",
      "// === File operations ===",
      "Bash(awk:*)",
      "Bash(bunx biome:*)",
      "Bash(bunx prettier:*)",
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(dprint:*)",
      "Bash(du:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(mktemp:*)",
      "Bash(npx biome:*)",
      "Bash(npx prettier:*)",
      "Bash(python3 --version:*)",
      "Bash(readlink:*)",
      "Bash(ruff:*)",
      "Bash(sort:*)",
      "Bash(stat:*)",
      "Bash(tail:*)",
      "Bash(time:*)",
      "Bash(uniq:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(xargs ls:*)",
      "// === Date/Time ===",
      "Bash(TZ=Asia/Tokyo date:*)",
      "// === Docker ===",
      "Bash(docker exec:*)",
      "Bash(docker ps:*)",
      "// === Web ===",
      "WebSearch",
      "WebFetch(domain:addyosmani.com)",
      "WebFetch(domain:getoban.pro)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:hex.pm)",
      "WebFetch(domain:hexdocs.pm)",
      "WebFetch(domain:oban.pro)",
      "WebFetch(domain:www.anthropic.com)",
      "WebFetch(domain:zenn.dev)",
      "// === User directories (read-only) ===",
      "Read({{ .chezmoi.homeDir }}/.config/**)",
      "Read({{ .chezmoi.homeDir }}/.local/share/chezmoi/**)",
      "Read({{ .chezmoi.homeDir }}/.local/bin/**)",
      "Read({{ .chezmoi.homeDir }}/.claude/projects/**)",
      "// === Temp files ===",
      "Read(//tmp/*)",
      "Write(//tmp/*)",
      "Edit(//tmp/*)"
    ],
    "deny": [
      "// === Destructive operations ===",
      "Bash(unlink:*)",
      "Bash(unlink *)",
      "Bash(shred:*)",
      "Bash(shred *)",
      "// === Privilege escalation ===",
      "Bash(sudo:*)",
      "Bash(sudo *)",
      "Bash(su:*)",
      "Bash(su *)",
      "// === Network tools ===",
      "Bash(wget:*)",
      "Bash(wget *)",
      "Bash(nc:*)",
      "Bash(nc *)",
      "Bash(ncat:*)",
      "Bash(ncat *)",
      "Bash(telnet:*)",
      "Bash(telnet *)",
      "// === macOS sensitive ===",
      "Bash(osascript:*)",
      "Bash(osascript *)",
      "Bash(security:*)",
      "Bash(security *)",
      "Bash(open:*)",
      "Bash(open *)",
      "Bash(pbcopy:*)",
      "Bash(pbcopy *)",
      "Bash(pbpaste:*)",
      "Bash(pbpaste *)",
      "// === Sensitive file access ===",
      "Bash(* .env*)",
      "Bash(* ~/.ssh/*)",
      "Bash(* ~/.aws/*)",
      "Bash(* ~/.config/gh/*)",
      "Bash(* ~/.netrc)",
      "Bash(* ~/.npmrc)",
      "Read(.env)",
      "Read(.env.*)",
      "Read({{ .chezmoi.homeDir }}/.ssh/**)",
      "Read({{ .chezmoi.homeDir }}/.aws/**)",
      "Read({{ .chezmoi.homeDir }}/.config/gh/**)",
      "Read({{ .chezmoi.homeDir }}/.netrc)"
