# Unix
alias ls='eza'
alias ll='eza -la --icons --git --time-style=long-iso --sort=modified'
alias lt='eza --tree --level=2 --icons'
alias ln='ln -v'
alias mkdir='mkdir -p'

# Git
alias lg='lazygit'

# Pretty print the path
alias path='echo $PATH | tr -s ":" "\n"'

# Include custom aliases
[[ -f ~/.aliases.local ]] && source ~/.aliases.local

# Use nvim as vim
alias vim='nvim'

# docker compose
# I don't use dc command...
alias dc="docker compose"
alias dcps="dc ps --format 'table {{.Name}}\t{{.Image}}\t{{.Ports}}\t{{.Status}}\t{{.Size}}'"

# claude-code
alias claude='claude --debug'
alias cost="bunx ccusage@latest"

# gemini
alias gemini='bunx @google/gemini-cli@latest'

# directory
alias memo="cd $HOME/src/github.com/bobstrange/memot/work/spideraf/"
alias prdb="cd $HOME/src/github.com/bobstrange/elixir-playground/"
alias agent-config="cd $HOME/src/github.com/bobstrange/agent-configs/"
